            <a href="#how" style={styles.navLink}>How it works</a>
            <a href="#examples" style={styles.navLink}>Features</a>
            <button style={styles.navBtn}>Log in</button>
          </div>
        </nav>

        {/* HERO */}
        <div style={styles.heroWrapper}>
          <div>
            <div style={styles.badge}>
              <span style={styles.badgeDot} />
              Powered by AI
            </div>
            <h1 style={styles.heroH1}>
              Books you'll actually{" "}
              <span style={styles.heroH1Accent}>love.</span>
            </h1>
            <p style={styles.heroP}>
              Tell us three books you enjoyed. Our AI breaks down what you
              really liked and finds your perfect next read.
            </p>
            <div style={styles.heroActions}>
              <button style={styles.btnMain}>Try it free</button>
              <button style={styles.btnGhost}>See how it works</button>
            </div>
            <div style={styles.heroStats}>
              {stats.map((s) => (
                <div key={s.label}>
                  <div style={styles.statNum}>{s.num}</div>
                  <div style={styles.statLabel}>{s.label}</div>
                </div>
              ))}
            </div>
          </div>

          {/* Floating book previews */}
          <div style={styles.heroRight}>
            {mockBooks.map((book, i) => (
              <div
                key={book.isbn}
                style={{
                  ...styles.floatingCard,
                  marginLeft: ["0", "2rem", "1rem"][i],
                }}
              >
                <img style={styles.fcCover} src={book.image} alt={book.title} />
                <div>
                  <div style={styles.fcTitle}>{book.title}</div>
                  <div style={styles.fcAuthor}>{book.authors}</div>
                  <span style={styles.fcTag}>{book.genre}</span>
                </div>
              </div>
            ))}
          </div>
        </div>

        {/* INPUT DEMO */}
        <div style={styles.inputSection}>
          <div style={styles.inputInner}>
            <div style={styles.eyebrow}>Try it now</div>
            <h2 style={styles.sectionH2}>What have you loved reading?</h2>
            <p style={styles.sectionSubP}>Enter three books and we'll do the rest.</p>
            <div style={styles.inputStack}>
              {[
                "A book you couldn't put down...",
                "Another you remember fondly...",
                "One more that stayed with you...",
              ].map((placeholder, i) => (
                <input
                  key={i}
                  style={styles.inp}
                  placeholder={placeholder}
                  value={inputs[i]}
                  onChange={(e) => handleInput(i, e.target.value)}
                />
              ))}
            </div>
            <button style={styles.btnFull}>Generate my recommendations →</button>
          </div>
        </div>

        {/* HOW IT WORKS */}
        <div id="how" style={styles.stepsSection}>
          <h2 style={styles.sectionH2}>Simple as 1, 2, 3.</h2>
          <div style={styles.stepsGrid}>
            {steps.map((step) => (
              <div key={step.title} style={styles.stepCard}>
                <div style={{ ...styles.stepIcon, background: step.iconBg }}>
                  {step.icon}
                </div>
                <h3 style={styles.stepH3}>{step.title}</h3>
                <p style={styles.stepP}>{step.desc}</p>
              </div>
            ))}
          </div>
        </div>

        {/* EXAMPLE RECOMMENDATIONS — your existing BookCard, completely unchanged */}
        <div id="examples" style={styles.booksSection}>
          <div style={styles.booksInner}>
            <div style={styles.eyebrow}>Examples</div>
            <h2 style={styles.sectionH2}>Example recommendations.</h2>
            <p style={styles.booksSubP}>
              Here's what BookMatch might suggest for a fan of epic fantasy.
            </p>
            <div style={styles.booksGrid}>
              {mockBooks.map((book, index) => (
                <BookCard key={index} {...book} />
              ))}
            </div>
          </div>
        </div>

        {/* CTA */}
        <div style={styles.ctaSection}>
          <h2 style={styles.ctaH2}>Ready to find your next favorite book?</h2>
          <button style={styles.btnWhite}>Start matching for free</button>
        </div>

        {/* FOOTER */}
        <footer style={styles.footer}>
          <p style={styles.footerP}>© 2026 BookMatch AI</p>
          <p style={styles.footerP}>Made with taste.</p>
        </footer>

      </div>
    </>
