export default function Index() {
  const [inputs, setInputs] = useState(["", "", ""]);

  const handleInput = (i, val) => {
    const next = [...inputs];
    next[i] = val;
    setInputs(next);
  };

  return (
    <>
      <link
        href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Instrument+Sans:wght@300;400;500&display=swap"
        rel="stylesheet"
      />

      <div style={styles.root}>

        {/* NAV */}
        <nav style={styles.nav}>
          <div style={styles.logo}>
            Book<span style={styles.logoAccent}>Match</span>
          </div>
